{
  "id": "lancer-speed-provider",
  "title": "Lancer Ruler Integration",
  "description": "Provides Drag Ruler speed settings for Lancer",
  "authors": [{ "name": "Bolts" }],
  "type": "module",
  "version": "0.0a",
  "compatibility": {
    "minimum": "12",
    "verified": "12"
  },
  "relationships": {
    "systems": [
      {
        "id": "lancer",
        "type": "system",
        "compatibility": {
          "minimum": "2.0.0",
          "verified": "2.1.5"
        }
      }
    ],
    "recommends": [
      {
        "id": "drag-ruler",
        "type": "module",
        "reason": "Either Drag Ruler or Elevation Ruler is required. Elevation Ruler is recommended. They conflict, so only enable one"
      },
      {
        "id": "elevationruler",
        "type": "module",
        "reason": "Either Drag Ruler or Elevation Ruler is required. Elevation Ruler is recommended. They conflict, so only enable one"
      }
    ]
  },
  "esmodules": ["./lancer-provider.js"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "url": "https://github.com/BoltsJ/lancer-speed-provider.git",
  "manifest": "https://raw.githubusercontent.com/BoltsJ/lancer-speed-provider/main/module.json",
  "download": "https://github.com/BoltsJ/lancer-speed-provider/archive/default.zip"
}
